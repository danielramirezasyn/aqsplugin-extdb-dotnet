<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <!-- Microsoft.Data.SqlClient requires full ICU globalization (culture-aware collation
         handling); InvariantGlobalization=true makes it fail at connection time with
         "Globalization Invariant Mode is not supported." -->
    <InvariantGlobalization>false</InvariantGlobalization>
    <RootNamespace>AqsPluginExtDb</RootNamespace>
    <UserSecretsId>aqsplugin-extdb-dotnet</UserSecretsId>
    <DockerDefaultTargetOS>Linux</DockerDefaultTargetOS>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Data.SqlClient" Version="7.0.2" />
    <PackageReference Include="MySqlConnector" Version="2.6.1" />
    <PackageReference Include="Npgsql" Version="10.0.3" />
  </ItemGroup>

</Project>
